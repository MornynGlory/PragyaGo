'use client';

import { useEffect, useState } from 'react';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL || '',
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || ''
);

interface Ride {
  id: string;
  rider_name: string;
  driver_name: string;
  pickup_address: string;
  dropoff_address: string;
  fare: number;
  payment_method: string;
  status: string;
  created_at: string;
}

export default function AdminRides() {
  const [rides, setRides] = useState<Ride[]>([]);
  const [filteredRides, setFilteredRides] = useState<Ride[]>([]);
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [password, setPassword] = useState('');
  const [dateFilter, setDateFilter] = useState('');
  const [statusFilter, setStatusFilter] = useState('');
  const [loading, setLoading] = useState(false);

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (password === process.env.NEXT_PUBLIC_ADMIN_PASSWORD) {
      setIsAuthenticated(true);
      setPassword('');
      fetchRides();
    } else {
      alert('Invalid password');
      setPassword('');
    }
  };

  const fetchRides = async () => {
    setLoading(true);
    try {
      const { data, error } = await supabase
        .from('rides')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) throw error;
      setRides(data || []);
      applyFilters(data || []);
    } catch (error) {
      console.error('Error fetching rides:', error);
      alert('Failed to fetch rides');
    } finally {
      setLoading(false);
    }
  };

  const applyFilters = (ridesToFilter: Ride[]) => {
    let filtered = ridesToFilter;

    if (dateFilter) {
      filtered = filtered.filter(
        (ride) =>
          new Date(ride.created_at).toLocaleDateString() ===
          new Date(dateFilter).toLocaleDateString()
      );
    }

    if (statusFilter) {
      filtered = filtered.filter((ride) => ride.status === statusFilter);
    }

    setFilteredRides(filtered);
  };

  const handleDateChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setDateFilter(e.target.value);
    applyFilters(rides);
  };

  const handleStatusChange = (e: React.ChangeEvent<HTMLSelectElement>) => {
    setStatusFilter(e.target.value);
    applyFilters(rides);
  };

  useEffect(() => {
    applyFilters(rides);
  }, [dateFilter, statusFilter, rides]);

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-100">
        <div className="bg-white p-8 rounded-lg shadow-lg">
          <h1 className="text-3xl font-bold mb-6 text-gray-800">PragyaGo Admin</h1>
          <form onSubmit={handleLogin} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Password
              </label>
              <input
                type="password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                placeholder="Enter admin password"
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <button
              type="submit"
              className="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition"
            >
              Login
            </button>
          </form>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-100 p-8">
      <div className="max-w-7xl mx-auto">
        <div className="flex justify-between items-center mb-8">
          <h1 className="text-4xl font-bold text-gray-800">Admin Rides</h1>
          <button
            onClick={() => {
              setIsAuthenticated(false);
              setRides([]);
              setFilteredRides([]);
            }}
            className="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition"
          >
            Logout
          </button>
        </div>

        <div className="bg-white p-6 rounded-lg shadow-lg mb-6">
          <h2 className="text-xl font-semibold mb-4 text-gray-700">Filters</h2>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Date
              </label>
              <input
                type="date"
                value={dateFilter}
                onChange={handleDateChange}
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Status
              </label>
              <select
                value={statusFilter}
                onChange={handleStatusChange}
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="">All Statuses</option>
                <option value="completed">Completed</option>
                <option value="pending">Pending</option>
                <option value="cancelled">Cancelled</option>
                <option value="in-progress">In Progress</option>
              </select>
            </div>
          </div>
          <button
            onClick={fetchRides}
            disabled={loading}
            className="mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition disabled:bg-gray-400"
          >
            {loading ? 'Loading...' : 'Refresh Rides'}
          </button>
        </div>

        <div className="bg-white rounded-lg shadow-lg overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full">
              <thead>
                <tr className="bg-gray-200 border-b">
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Rider Name
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Driver Name
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Pickup Address
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Dropoff Address
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Fare (GHS)
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Payment Method
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Status
                  </th>
                  <th className="px-6 py-3 text-left text-sm font-semibold text-gray-700">
                    Time
                  </th>
                </tr>
              </thead>
              <tbody>
                {filteredRides.length === 0 ? (
                  <tr>
                    <td colSpan={8} className="px-6 py-4 text-center text-gray-500">
                      No rides found
                    </td>
                  </tr>
                ) : (
                  filteredRides.map((ride) => (
                    <tr
                      key={ride.id}
                      className="border-b hover:bg-gray-50 transition"
                    >
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {ride.rider_name}
                      </td>
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {ride.driver_name}
                      </td>
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {ride.pickup_address}
                      </td>
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {ride.dropoff_address}
                      </td>
                      <td className="px-6 py-3 text-sm font-semibold text-gray-700">
                        {ride.fare.toFixed(2)}
                      </td>
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {ride.payment_method}
                      </td>
                      <td className="px-6 py-3 text-sm">
                        <span
                          className={`px-3 py-1 rounded-full text-xs font-semibold ${
                            ride.status === 'completed'
                              ? 'bg-green-100 text-green-800'
                              : ride.status === 'pending'
                              ? 'bg-yellow-100 text-yellow-800'
                              : ride.status === 'in-progress'
                              ? 'bg-blue-100 text-blue-800'
                              : 'bg-red-100 text-red-800'
                          }`}
                        >
                          {ride.status}
                        </span>
                      </td>
                      <td className="px-6 py-3 text-sm text-gray-700">
                        {new Date(ride.created_at).toLocaleString()}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
}

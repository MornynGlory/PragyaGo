writeFile('app/_layout.tsx', `"use client"

import { useEffect } from 'react'
import { useRouter } from 'next/navigation'
import { getCurrentUser, onAuthStateChange } from '../lib/supabase'
import type { ReactNode } from 'react'

export default function RootLayout({ children }: { children: ReactNode }) {
  const router = useRouter()

  useEffect(() => {
    let isMounted = true

    async function initialize() {
      const current = await getCurrentUser()
      if (!isMounted) return

      if (current.user) {
        const destination = current.role === 'Driver' ? '/driver/home' : '/rider/home'
        if (window.location.pathname === '/' || window.location.pathname.startsWith('/auth')) {
          router.replace(destination)
        }
      }
    }

    initialize()

    const subscription = onAuthStateChange((event, sessionUser) => {
      if (!sessionUser) {
        if (window.location.pathname !== '/') {
          router.replace('/')
        }
        return
      }

      const userRole = sessionUser.user_metadata?.role === 'Driver' ? 'Driver' : 'Rider'
      if (window.location.pathname === '/' || window.location.pathname.startsWith('/auth')) {
        router.replace(userRole === 'Driver' ? '/driver/home' : '/rider/home')
      }
    })

    return () => {
      isMounted = false
      subscription?.unsubscribe?.()
    }
  }, [router])

  return (
    <html lang="en">
      <body>{children}</body>
    </html>
  )
}
`)

writeFile('lib/supabase.ts', `import { createClient } from '@supabase/supabase-js'

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL || ''
const supabaseKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || ''

export const supabase = createClient(supabaseUrl, supabaseKey)

export type AuthUser = {
  id: string
  phone?: string | null
  full_name?: string | null
  role?: 'Rider' | 'Driver' | null
}

function mapUser(user: any): AuthUser {
  return {
    id: user.id,
    phone: user.phone ?? null,
    full_name: user.user_metadata?.full_name ?? null,
    role: user.user_metadata?.role === 'Driver' ? 'Driver' : 'Rider',
  }
}

export async function signUp(full_name: string, phone: string, password: string, role: 'Rider' | 'Driver') {
  const { data, error } = await supabase.auth.signUp({ phone, password }, { data: { full_name, role } })
  return {
    user: data?.user ? mapUser(data.user) : null,
    error,
  }
}

export async function signIn(phone: string, password: string) {
  const { data, error } = await supabase.auth.signInWithPassword({ phone, password })
  return {
    user: data?.user ? mapUser(data.user) : null,
    error,
  }
}

export async function signOut() {
  const { error } = await supabase.auth.signOut()
  return { error }
}

export async function getCurrentUser() {
  const { data, error } = await supabase.auth.getSession()
  if (error) {
    return { user: null, role: null }
  }

  const user = data?.session?.user
  if (!user) {
    return { user: null, role: null }
  }

  const mapped = mapUser(user)
  return {
    user: mapped,
    role: mapped.role,
  }
}

export function onAuthStateChange(callback: (event: string, user: any | null) => void) {
  return supabase.auth.onAuthStateChange((event, session) => {
    callback(event, session?.user ?? null)
  })
}
`)


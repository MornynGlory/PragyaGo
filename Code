## Setup Instructions

### 1. Create the project structure

```bash
cd c:\Users\USER\PragyaGo
npx create-expo-app@latest Code --template
cd Code
```

### 2. Install dependencies

```bash
npm install
npm install expo-router
npm install @react-navigation/native @react-navigation/bottom-tabs @react-navigation/native-stack
npm install react-native-screens react-native-safe-area-context
npm install @supabase/supabase-js
npm install typescript @types/react @types/react-native --save-dev
npx expo install expo-font expo-splash-screen
```

### 3. Key Files Implementation

#### app/_layout.tsx
```typescript
import { Stack } from 'expo-router';
import { useUserRole } from '@/hooks/useUserRole';
import { ActivityIndicator, View } from 'react-native';

export default function RootLayout() {
  const { role, loading } = useUserRole();

  if (loading) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <ActivityIndicator size="large" />
      </View>
    );
  }

  return (
    <Stack screenOptions={{ headerShown: false }}>
      {role === null ? (
        <Stack.Screen name="index" />
      ) : role === 'rider' ? (
        <Stack.Screen name="rider" />
      ) : (
        <Stack.Screen name="driver" />
      )}
    </Stack>
  );
}
```

#### app/index.tsx (Role Selection)
```typescript
import React, { useState } from 'react';
import { View, Text, StyleSheet, TouchableOpacity } from 'react-native';
import { router } from 'expo-router';
import { COLORS } from '@/constants/colors';

export default function RoleSelection() {
  const [loading, setLoading] = useState(false);

  const handleRoleSelection = async (role: 'rider' | 'driver') => {
    setLoading(true);
    // Store role preference in AsyncStorage or context
    // For now, navigate directly
    if (role === 'rider') {
      router.replace('/rider');
    } else {
      router.replace('/driver');
    }
    setLoading(false);
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>Welcome to PragyaGo</Text>
      <Text style={styles.subtitle}>Choose your role</Text>

      <TouchableOpacity
        style={[styles.button, styles.riderButton]}
        onPress={() => handleRoleSelection('rider')}
        disabled={loading}
      >
        <Text style={styles.buttonText}>🚗 I'm a Rider</Text>
      </TouchableOpacity>

      <TouchableOpacity
        style={[styles.button, styles.driverButton]}
        onPress={() => handleRoleSelection('driver')}
        disabled={loading}
      >
        <Text style={styles.buttonText}>🚙 I'm a Driver</Text>
      </TouchableOpacity>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center',
